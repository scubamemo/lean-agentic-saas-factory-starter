{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic.factory.WorkOrderState.v4",
  "title": "Agentic Factory Observability Work Order State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "work_order_id",
    "module",
    "task_type",
    "status",
    "last_updated_by",
    "validation_errors",
    "owner",
    "next_agent",
    "allowed_transitions",
    "quality_gates",
    "artifacts",
    "mcp",
    "history_summary",
    "delta_policy",
    "agent_payloads",
    "template_cache",
    "approval_required",
    "approved_by",
    "approval_notes",
    "observability"
  ],
  "properties": {
    "schema": {
      "const": "agentic.factory.WorkOrderState.v4"
    },
    "work_order_id": {
      "type": "string",
      "pattern": "^WO-[0-9A-Za-z._-]+$"
    },
    "module": {
      "type": "string",
      "minLength": 1
    },
    "task_type": {
      "type": "string",
      "enum": [
        "docs-only",
        "contract-only",
        "backend-only",
        "frontend-only",
        "data-model",
        "full-stack",
        "bugfix",
        "refactor",
        "review",
        "release"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "PLANNED",
        "IN_PROGRESS",
        "VALIDATION_REQUIRED",
        "QA_PENDING",
        "APPROVED",
        "COMPLETED",
        "FAILED"
      ]
    },
    "last_updated_by": {
      "type": "string",
      "minLength": 1
    },
    "validation_errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warning",
              "error"
            ]
          }
        }
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "next_agent": {
      "type": "string",
      "minLength": 1
    },
    "allowed_transitions": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "PLANNED",
            "IN_PROGRESS",
            "VALIDATION_REQUIRED",
            "QA_PENDING",
            "APPROVED",
            "COMPLETED",
            "FAILED"
          ]
        }
      }
    },
    "requested_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "requested_by",
        "reason"
      ],
      "properties": {
        "from": {
          "type": "string",
          "enum": [
            "PLANNED",
            "IN_PROGRESS",
            "VALIDATION_REQUIRED",
            "QA_PENDING",
            "APPROVED",
            "COMPLETED",
            "FAILED"
          ]
        },
        "to": {
          "type": "string",
          "enum": [
            "PLANNED",
            "IN_PROGRESS",
            "VALIDATION_REQUIRED",
            "QA_PENDING",
            "APPROVED",
            "COMPLETED",
            "FAILED"
          ]
        },
        "requested_by": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "quality_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "factory_check_passed",
        "dependency_check_passed",
        "contract_artifacts_valid",
        "dto_check_passed",
        "template_cache_valid",
        "test_matrix_criteria_met",
        "qa_passed",
        "review_passed",
        "spec_kit_contracts_valid",
        "security_scan_passed",
        "trace_logged"
      ],
      "properties": {
        "factory_check_passed": {
          "type": "boolean"
        },
        "dependency_check_passed": {
          "type": "boolean"
        },
        "contract_artifacts_valid": {
          "type": "boolean"
        },
        "dto_check_passed": {
          "type": "boolean"
        },
        "template_cache_valid": {
          "type": "boolean"
        },
        "test_matrix_criteria_met": {
          "type": "boolean"
        },
        "qa_passed": {
          "type": "boolean"
        },
        "review_passed": {
          "type": "boolean"
        },
        "spec_kit_contracts_valid": {
          "type": "boolean"
        },
        "security_scan_passed": {
          "type": "boolean"
        },
        "trace_logged": {
          "type": "boolean"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "api_contract",
        "ui_contract",
        "dto",
        "data_model",
        "test_matrix",
        "handoff"
      ],
      "properties": {
        "api_contract": {
          "type": "string"
        },
        "ui_contract": {
          "type": "string"
        },
        "dto": {
          "type": "string"
        },
        "data_model": {
          "type": "string"
        },
        "test_matrix": {
          "type": "string"
        },
        "handoff": {
          "type": "string"
        }
      }
    },
    "mcp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_of_truth",
        "structured_handoffs_required",
        "active_work_order_md_is_mirror",
        "lazy_context_required"
      ],
      "properties": {
        "source_of_truth": {
          "const": "project/work-orders/state.json"
        },
        "structured_handoffs_required": {
          "type": "boolean",
          "const": true
        },
        "active_work_order_md_is_mirror": {
          "type": "boolean"
        },
        "lazy_context_required": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "history_summary": {
      "type": "string",
      "const": "project/work-orders/history-summary.json"
    },
    "template_cache": {
      "type": "string",
      "const": "project/work-orders/template-structure-cache.json"
    },
    "delta_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "delta_only_writing",
        "role_payload_keys",
        "forbid_full_markdown_rewrites"
      ],
      "properties": {
        "delta_only_writing": {
          "type": "boolean",
          "const": true
        },
        "forbid_full_markdown_rewrites": {
          "type": "boolean",
          "const": true
        },
        "role_payload_keys": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "agent_payloads": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pm_status",
        "architect_status",
        "data_status",
        "backend_status",
        "ui_status",
        "qa_status",
        "review_status"
      ],
      "properties": {
        "pm_status": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "summary",
            "updated_by",
            "changed_artifacts"
          ],
          "properties": {
            "status": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "updated_by": {
              "type": "string"
            },
            "changed_artifacts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "architect_status": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "summary",
            "updated_by",
            "changed_artifacts"
          ],
          "properties": {
            "status": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "updated_by": {
              "type": "string"
            },
            "changed_artifacts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "data_status": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "summary",
            "updated_by",
            "changed_artifacts"
          ],
          "properties": {
            "status": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "updated_by": {
              "type": "string"
            },
            "changed_artifacts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "backend_status": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "summary",
            "updated_by",
            "changed_artifacts"
          ],
          "properties": {
            "status": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "updated_by": {
              "type": "string"
            },
            "changed_artifacts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "ui_status": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "summary",
            "updated_by",
            "changed_artifacts"
          ],
          "properties": {
            "status": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "updated_by": {
              "type": "string"
            },
            "changed_artifacts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "qa_status": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "summary",
            "updated_by",
            "changed_artifacts"
          ],
          "properties": {
            "status": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "updated_by": {
              "type": "string"
            },
            "changed_artifacts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "review_status": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "summary",
            "updated_by",
            "changed_artifacts"
          ],
          "properties": {
            "status": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "updated_by": {
              "type": "string"
            },
            "changed_artifacts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_required": {
      "type": "boolean"
    },
    "approved_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "approval_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "trace_dir",
        "trace_required_before_completion",
        "trace_format"
      ],
      "properties": {
        "trace_dir": {
          "type": "string"
        },
        "trace_required_before_completion": {
          "type": "boolean"
        },
        "trace_format": {
          "type": "string"
        }
      }
    }
  }
}
