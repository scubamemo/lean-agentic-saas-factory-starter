{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic.factory.SpecKitModuleSpec.v1",
  "title": "Agentic Spec-Kit Module Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "module",
    "version",
    "status",
    "resources",
    "dto_schemas",
    "endpoints",
    "permissions",
    "ui_surfaces",
    "events",
    "spec",
    "plan",
    "data_model",
    "contracts",
    "tasks",
    "quickstart_checks",
    "validation"
  ],
  "properties": {
    "schema": {
      "const": "agentic.factory.SpecKitModuleSpec.v1"
    },
    "module": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$|^<module-name>$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "contract-ready",
        "implementation-ready",
        "implemented",
        "validated"
      ]
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/resource"
      }
    },
    "dto_schemas": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/jsonSchema"
      }
    },
    "endpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/endpoint"
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/permission"
      }
    },
    "ui_surfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/uiSurface"
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "summary",
        "user_stories",
        "acceptance_criteria",
        "non_goals"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "user_stories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "plan": {
      "type": "object",
      "additionalProperties": true
    },
    "data_model": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "entities"
      ]
    },
    "contracts": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "openapi",
        "schemas",
        "permissions"
      ],
      "properties": {
        "openapi": {
          "type": "object",
          "required": [
            "openapi",
            "info",
            "paths"
          ]
        },
        "schemas": {
          "type": "object"
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "quickstart_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "contract_source_of_truth",
        "markdown_mirror"
      ],
      "properties": {
        "contract_source_of_truth": {
          "type": "string"
        },
        "markdown_mirror": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "jsonSchema": {
      "type": "object",
      "required": [
        "type"
      ],
      "additionalProperties": true
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "ownership",
        "dto",
        "tenant_owned"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "ownership": {
          "type": "string",
          "enum": [
            "tenant-owned",
            "platform-owned",
            "mixed",
            "none"
          ]
        },
        "dto": {
          "type": "string",
          "minLength": 1
        },
        "tenant_owned": {
          "type": "boolean"
        }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operationId",
        "method",
        "path",
        "request_schema",
        "response_schema",
        "error_codes",
        "permission"
      ],
      "properties": {
        "operationId": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "request_schema": {
          "type": "string"
        },
        "response_schema": {
          "type": "string",
          "minLength": 1
        },
        "error_codes": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "permission": {
          "type": "string"
        }
      }
    },
    "permission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "uiSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "purpose",
        "states",
        "actions"
      ],
      "properties": {
        "route": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string"
        },
        "states": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "schema",
        "when"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "schema": {
          "type": "string"
        },
        "when": {
          "type": "string"
        }
      }
    }
  }
}
