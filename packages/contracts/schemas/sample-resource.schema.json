{
  "SampleResourceDto": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "name",
      "createdAt",
      "updatedAt"
    ],
    "properties": {
      "id": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "createdAt": {
        "type": "string",
        "format": "date-time"
      },
      "updatedAt": {
        "type": "string",
        "format": "date-time"
      }
    }
  },
  "CreateSampleResourceRequest": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "name"
    ],
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "SampleResourceListResponse": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "items",
      "page",
      "pageSize",
      "total"
    ],
    "properties": {
      "items": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/SampleResourceDto"
        }
      },
      "page": {
        "type": "integer"
      },
      "pageSize": {
        "type": "integer"
      },
      "total": {
        "type": "integer"
      }
    }
  }
}
