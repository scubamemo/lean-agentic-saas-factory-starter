{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic.factory.AgentHandoff.v1",
  "title": "Agent Handoff Payload",
  "description": "Machine-readable handoff payload required in module handoff.md files. Free-text notes may exist, but this payload is the validator-owned handoff contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_agent",
    "target_agent",
    "work_order_id",
    "module",
    "current_state",
    "next_state",
    "contract_version",
    "changed_artifacts",
    "changed_files",
    "scripts_run",
    "validation_errors",
    "blockers",
    "next_action"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "agentic.factory.AgentHandoff.v1"
    },
    "source_agent": {
      "$ref": "#/$defs/agent"
    },
    "target_agent": {
      "$ref": "#/$defs/agent"
    },
    "work_order_id": {
      "type": "string",
      "pattern": "^WO-[0-9A-Za-z._-]+$"
    },
    "module": {
      "type": "string",
      "minLength": 1
    },
    "current_state": {
      "$ref": "#/$defs/work_order_state"
    },
    "next_state": {
      "$ref": "#/$defs/work_order_state"
    },
    "contract_version": {
      "type": "string",
      "minLength": 1
    },
    "changed_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repository_path"
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repository_path"
      }
    },
    "scripts_run": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_errors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "agent": {
      "type": "string",
      "enum": [
        "pm",
        "architect",
        "designer",
        "data-engineer",
        "backend-developer",
        "frontend-developer",
        "qa",
        "code-reviewer",
        "human"
      ]
    },
    "work_order_state": {
      "type": "string",
      "enum": [
        "PLANNED",
        "IN_PROGRESS",
        "VALIDATION_REQUIRED",
        "QA_PENDING",
        "APPROVED",
        "COMPLETED",
        "FAILED",
        "REVISION_IN_PROGRESS"
      ]
    },
    "repository_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$"
    }
  }
}
