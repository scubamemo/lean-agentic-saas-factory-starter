NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_PORT=3000
APP_BASE_DOMAIN=localhost
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

DATABASE_URL=postgresql://app_user:app_pass@postgres:5432/app_db?schema=public
PLATFORM_DATABASE_URL=postgresql://app_user:app_pass@postgres:5432/app_db?schema=platform
TENANCY_DEFAULT_DB_MODE=shared
TENANCY_DEDICATED_ENABLED=false
TENANCY_LOCAL_HEADER=x-tenant-slug

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres

REDIS_URL=redis://redis:6379
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_BUCKET=dev-bucket
SECRETS_PROVIDER=local
